msgstr "Карта впровадження"

#: ../src/Plugins/MailChimp/v2/templates/settings.php:208
msgid "API key and timeout"
msgstr "Ключ API та час очікування"

#: ../src/Plugins/MailChimp/v2/templates/settings.php:209
