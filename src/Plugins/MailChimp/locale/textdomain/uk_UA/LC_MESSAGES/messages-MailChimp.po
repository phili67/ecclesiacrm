msgstr "Це значення можна вставити перед згенерованим HTML-кодом кампанії."

#: ../src/Plugins/MailChimp/v2/templates/settings.php:194
msgid "Extra font CSS"
msgstr "Додаткові стилі шрифтів у CSS"

#: ../src/Plugins/MailChimp/v2/templates/settings.php:198
