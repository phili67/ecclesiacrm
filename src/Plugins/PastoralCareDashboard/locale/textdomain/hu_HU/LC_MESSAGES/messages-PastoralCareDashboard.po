#: ../src/Plugins/PastoralCareDashboard/v2/templates/View.php:83
#, fuzzy, php-format
msgid ""
"Less than 10% of members have been visited. Immediate pastoral action is "
"required!"
msgstr ""
"A tagok kevesebb mint 10%-át keresték fel. Azonnali lelkipásztori "
"intézkedésre van szükség!"

