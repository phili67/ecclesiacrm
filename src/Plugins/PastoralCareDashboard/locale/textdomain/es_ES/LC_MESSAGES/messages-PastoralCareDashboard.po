#: ../src/Plugins/PastoralCareDashboard/v2/templates/View.php:68
#, php-format
msgid ""
"More than 60% of members have been visited. Keep up the great pastoral work!"
msgstr ""
"Más del 60% de los miembros han sido visitados. ¡Seguid con el gran trabajo "
"pastoral!"

