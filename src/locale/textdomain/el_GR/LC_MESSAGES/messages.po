msgstr "Κρυπτογράφηση αρχείου αντιγράφων ασφαλείας με κωδικό πρόσβασης;"

#: v2/templates/BackupRestore/backup.php:85
#: v2/templates/BackupRestore/restore.php:35
msgid "encryption"
msgstr "κρυπτογράφηση"

#: v2/templates/BackupRestore/backup.php:91
